{
  "$schema": "https://www.krakend.io/schema/v2.13/krakend.json",
  "version": 3,
  "output_encoding": "json",
  "name": "InventoryOrderAggregate",
  "port": 8081,
  "endpoints": [
    {
      "endpoint": "/orders/{id}",
      "method": "GET",
      "extra_config": {
        "proxy": {
          "sequential": true
        }
      },
      "output_encoding": "json",
      "backend": [
        {
          "url_pattern": "/orders/{id}",
          "encoding": "json",
          "method": "GET",
          "host": [
            "http://orderrecordservice:5000/"
          ],
          "disable_host_sanitize": false,
          "mapping": {
            "product_type": "type"
          },
          "deny": []
        },
        {
          "url_pattern": "/products/{resp0_type}",
          "encoding": "json",
          "method": "GET",
          "disable_host_sanitize": false,
          "deny": [
            "name"
          ],
          "sd": "static",
          "host": [
            "http://inventoryservice1:5000/",
	        "http://inventoryservice2:5000/"
          ]
        }
      ]
    }
  ],
  "timeout": "3000ms",
  "cache_ttl": "300s"
}